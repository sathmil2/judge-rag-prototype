# Copy this file to .env, then paste your real Azure values.
# The .env file is ignored by Git so secrets do not get pushed to GitHub.

OCR_PROVIDER=azure
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-read
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Optional SSL settings.
# Leave verification on for real use. Set AZURE_CA_BUNDLE only if your
# organization gives you a custom certificate bundle.
AZURE_VERIFY_SSL=true
AZURE_CA_BUNDLE=
